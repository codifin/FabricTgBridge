{
  "schemaVersion": 1,
  "id": "tgbridge",
  "version": "${version}",

  "name": "Telegram Мост",
  "description": "Синхронизация сообщений между группой в Telegram и игровым чатом сервера Fabric Minecraft.",
  "authors": [
    "坊洛"
  ],
  "contact": {
    "homepage": "https://cuteneko.eu.org/FabricTgBridge",
    "sources": "https://github.com/CuteNekoOwO/FabricTgBridge"
  },

  "license": "AGPL-3.0",
  "icon": "assets/tgbridge/icon.png",

  "environment": "server",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "cuteneko.tgbridge.Bridge"
      }
    ]
  },
  "mixins": [
    "tgbridge.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.21",
    "fabric": ">=0.58.0+1.18.2",
    "fabric-language-kotlin": ">=1.7.4+kotlin.1.6.21",
    "minecraft": "1.18.2"
  },
  "suggests": {
  }
}